+#ifdef _WIN32
+static gboolean windows_boolean_property(GObject *object, const char *name) {
+    GParamSpec *property = g_object_class_find_property(
+        G_OBJECT_GET_CLASS(object), name);
+    return property && G_PARAM_SPEC_VALUE_TYPE(property) == G_TYPE_BOOLEAN;
+}
+
+static gboolean configure_windows_fullscreen_sink(video_renderer_t *renderer,
+                                                   GstElement *sink) {
+    if (!windows_boolean_property(G_OBJECT(sink), "fullscreen")) {
+        return FALSE;
+    }
+
+    GObjectClass *klass = G_OBJECT_GET_CLASS(sink);
+    if (windows_boolean_property(G_OBJECT(sink), "enable-navigation-events")) {
+        g_object_set(G_OBJECT(sink), "enable-navigation-events", TRUE, NULL);
+    }
+    if (g_object_class_find_property(klass, "fullscreen-toggle-mode")) {
+        /* PROPERTY deliberately excludes the sink's Alt+Enter handler. */
+        gst_util_set_object_arg(G_OBJECT(sink), "fullscreen-toggle-mode", "property");
+    }
+    if (windows_boolean_property(G_OBJECT(sink), "fullscreen-on-alt-enter")) {
+        g_object_set(G_OBJECT(sink), "fullscreen-on-alt-enter", FALSE, NULL);
+    }
+    if (!renderer->fullscreen_initialized) {
+        if (renderer->initial_fullscreen) {
+            g_object_set(G_OBJECT(sink), "fullscreen", TRUE, NULL);
+        }
+        renderer->fullscreen_initialized = TRUE;
+    }
+    return TRUE;
+}
+
+static GstElement *find_windows_fullscreen_sink(video_renderer_t *renderer,
+                                                GstObject *source) {
+    if (GST_IS_ELEMENT(source) && configure_windows_fullscreen_sink(
+            renderer, GST_ELEMENT(source))) {
+        return GST_ELEMENT(gst_object_ref(source));
+    }
+
+    GstIterator *iterator = gst_bin_iterate_recurse(GST_BIN(renderer->pipeline));
+    GValue item = G_VALUE_INIT;
+    GstElement *sink = NULL;
+    gboolean done = FALSE;
+    while (!done) {
+        switch (gst_iterator_next(iterator, &item)) {
+        case GST_ITERATOR_OK: {
+            GstElement *element = GST_ELEMENT(g_value_get_object(&item));
+            if (configure_windows_fullscreen_sink(renderer, element)) {
+                sink = GST_ELEMENT(gst_object_ref(element));
+                done = TRUE;
+            }
+            g_value_reset(&item);
+            break;
+        }
+        case GST_ITERATOR_RESYNC:
+            gst_iterator_resync(iterator);
+            break;
+        default:
+            done = TRUE;
+            break;
+        }
+    }
+    if (G_VALUE_TYPE(&item) != 0) {
+        g_value_unset(&item);
+    }
+    gst_iterator_free(iterator);
+    return sink;
+}
+
+static gboolean toggle_windows_fullscreen(video_renderer_t *renderer,
+                                          GstMessage *message) {
+    GstElement *sink = find_windows_fullscreen_sink(
+        renderer, GST_MESSAGE_SRC(message));
+    if (!sink) {
+        logger_log(logger, LOGGER_WARNING,
+                   "Fullscreen input received, but active videosink has no fullscreen property");
+        return FALSE;
+    }
+
+    gboolean fullscreen = FALSE;
+    g_object_get(G_OBJECT(sink), "fullscreen", &fullscreen, NULL);
+    fullscreen = !fullscreen;
+    g_object_set(G_OBJECT(sink), "fullscreen", fullscreen, NULL);
+    logger_log(logger, LOGGER_INFO, "Windows D3D fullscreen toggled %s",
+               fullscreen ? "on" : "off");
+    gst_object_unref(sink);
+    return TRUE;
+}
